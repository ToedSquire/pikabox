<?xml version="1.0" encoding="utf-8"?>
<image schemaversion="7.4" name="pikabox_twilight">
    <description type="system">
        <author>Pikabox</author>
        <contact>help.pikabox@outlook.com</contact>
        <specification>Ubuntu, Mint, and Budgie</specification>
    </description>
    
    <preferences>
        <type image="iso" bootprofile="default" flags="overlay"/>
        <version>1.1.38</version>
        <packagemanager>apt</packagemanager>
    </preferences>

    <users>
        <user name="root" password="" pwdformat="plain" groups="root"/>
        <user name="pikaos" password="" pwdformat="plain" groups="users,wheel,sudo,audio,video"/>
    </users>

    <packages type="image">
        <package name="kiwi-dracut-live"/>
        <package name="budgie-desktop"/>
        <package name="lightdm"/>
        <package name="lightdm-gtk-greeter"/>
        <package name="zsh"/>
        <package name="snapd"/>
        <package name="flatpak"/>
        <package name="gnome-software-plugin-flatpak"/>
        <package name="linux-image-generic"/>
        <package name="dracut-live"/>
        <package name="systemd-sysv"/>
        <package name="sudo"/>
        <package name="grub-pc"/>
        <package name="grub-common"/>
    </packages>

    <repository type="apt-deb" alias="ubuntu-base" distribution="plucky" components="main universe multiverse restricted">
        <source path="http://archive.ubuntu.com/ubuntu/"/>
    </repository>
    <repository type="apt-deb" alias="ubuntu-updates" distribution="plucky-updates" components="main universe multiverse restricted">
        <source path="http://archive.ubuntu.com/ubuntu/"/>
    </repository>
</image>
